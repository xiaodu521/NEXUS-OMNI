# 7. 交叉验证模块
# ---------------------------------------------------------
class CrossValidationGraph:
    """交叉验证图谱计算模块"""
    def __init__(self):
        self.edges: List[Tuple[str, str, float]] = []

    async def run_n_squared_validation(self, agent_outputs: List[Dict[str, Any]], trace_id: str) -> int:
        logger.info(f"[{trace_id}] [交叉验证] 启动数据比对验证计算...")
        
        pairs = list(itertools.combinations(agent_outputs, 2))
        logger.info(f"[{trace_id}] 构建验证组总计: {len(pairs)}，计算开始。")
        
        async def validate_conflict(pair: Tuple[Dict, Dict]):
            agent_a, agent_b = pair
            score_a = agent_a.get('insights', 0)
            score_b = agent_b.get('insights', 0)
            merged = f"Data A (Score {score_a}) vs Data B (Score {score_b})"
            
            res = await async_llm_gateway(
                f"Find contradiction between: {merged}", 
                ModelTier.TIER_1_REASONING, 
                complexity=2.5,
                trace_id=trace_id
            )
            self.edges.append((agent_a['agent_id'], agent_b['agent_id'], res["confidence_score"]))

        try:
            await asyncio.wait_for(
                asyncio.gather(*(validate_conflict(p) for p in pairs)),
                timeout=120.0
            )
        except asyncio.TimeoutError:
            logger.warning(f"[{trace_id}] 交叉验证模块执行超时，系统已保存当前有效结果。")
            
        logger.info(f"[{trace_id}] [交叉验证] 计算完成。有效比对次数: {len(pairs)}。")
        return len(pairs)

