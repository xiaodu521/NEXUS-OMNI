# 9. 系统调度与执行入口
# ---------------------------------------------------------
class NexusOmniSystem:
    def __init__(self):
        self.vector_db = MockVectorDB()
        self.validation_graph = CrossValidationGraph()
        self.mcts_engine = MCTSEngine()
        self.run_trace_id = f"NEXUS-{str(uuid.uuid4())[:8].upper()}"

    async def execute_full_pipeline(self, target_industry: str, raw_data_mb: int) -> dict:
        trace_id = self.run_trace_id
        logger.info(f"[{trace_id}] === 系统任务启动 ===")
        
        try:
            logger.info(f"[{trace_id}] [Phase 1] 启动数据摄入与向量化过程...")
            mock_data = f"{target_industry} risk factors and competitive data... " * 1000
            self.vector_db.ingest("Industry_Corpus", mock_data)

            logger.info(f"[{trace_id}] [Phase 2] 执行智能体集群初始化...")
            entities = ["Apple", "Nvidia", "Tesla", "OpenAI"]
            agents = [ExtractionAgent(f"{ent}-Ex-{i}", ent) for ent in entities for i in range(2)]
            agents.extend([RedTeamAgent(f"RedTeam-{i}") for i in range(2)])
            logger.info(f"[{trace_id}] 集群初始化完成，活动智能体数量: {len(agents)}")

            logger.info(f"[{trace_id}] [Phase 3] 执行并行信息提取...")
            context_str = " ".join(self.vector_db.similarity_search("Strategic Risks"))
            tasks = [agent.process(context_str, trace_id) for agent in agents]
            
            extraction_results = await asyncio.wait_for(asyncio.gather(*tasks), timeout=60.0)

            logger.info(f"[{trace_id}] [Phase 4] 执行数据一致性验证计算...")
            validation_count = await self.validation_graph.run_n_squared_validation(extraction_results, trace_id)

            logger.info(f"[{trace_id}] [Phase 5] 启动宏观战略推演...")
            initial_board = WargameState(market_share=0.15, turn=0)
            best_move = await self.mcts_engine.run_search(initial_board, context_str, iterations=10, trace_id=trace_id)
            
            return self.generate_strategy_report(target_industry, best_move, len(agents), validation_count)

        except BudgetExceededException as e:
            logger.error(f"[{trace_id}] 触发资金管理限制，任务安全终止。终止原因: {e}")
            return self.generate_error_report("BUDGET_EXCEEDED")
        except Exception as e:
            logger.error(f"[{trace_id}] 系统核心模块运行异常: {e}", exc_info=True)
            return self.generate_error_report(str(e))

    def generate_strategy_report(self, industry: str, best_move: str, agent_count: int, val_count: int) -> dict:
        """生成标准化系统评估报告"""
        audit = global_token_mgr.get_audit_data()
        report = {
            "metadata": {
                "system_version": "Nexus-Omni",
                "trace_id": self.run_trace_id,
                "timestamp": time.strftime("%Y-%m-%d %H:%M:%S")
            },
            "strategic_intelligence": {
                "target_industry": industry,
                "recommended_strategy": best_move,
                "confidence_level": "High"
            },
            "computational_metrics": {
                "active_agents": agent_count,
                "validations_executed": val_count,
                "resource_cost_usd": audit["total_cost_usd"]
            }
        }
        
        logger.info("-" * 40)
        logger.info("[战略评估报告生成完成]")
        logger.info(json.dumps(report, indent=4, ensure_ascii=False))
        logger.info("-" * 40)
        
        return report

    def generate_error_report(self, reason: str) -> dict:
        return {"status": "FAILED", "trace_id": self.run_trace_id, "error_reason": reason}

if __name__ == "__main__":
    system = NexusOmniSystem()
    try:
        final_report = asyncio.run(system.execute_full_pipeline(target_industry="Global AI Infrastructure", raw_data_mb=200))
    except KeyboardInterrupt:
