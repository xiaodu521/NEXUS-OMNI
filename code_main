# 8. MCTS 战略推演引擎
# ---------------------------------------------------------
class WargameState:
    def __init__(self, market_share: float, turn: int):
        self.market_share = market_share
        self.turn = turn
        self.is_terminal = turn >= 3

    def get_possible_actions(self) -> List[str]:
        if self.is_terminal: return []
        return ["Initiate_Price_War_30%", "Acquire_Upstream_Supply", "Hold_Cash_and_Wait", "Triple_AI_CapEx"]

class MCTSNode:
    def __init__(self, state: WargameState, parent=None, action=None):
        self.state = state
        self.parent = parent
        self.action = action
        self.children: List['MCTSNode'] = []
        self.visits = 0
        self.value = 0.0

    def best_child(self, exploration_weight: float = 1.414) -> 'MCTSNode':
        best_score = -float('inf')
        best_node = None
        for child in self.children:
            if child.visits == 0: return child
            exploit = child.value / child.visits
            explore = math.sqrt(math.log(self.visits) / child.visits)
            score = exploit + exploration_weight * explore
            if score > best_score:
                best_score = score
                best_node = child
        return best_node

class MCTSEngine:
    async def simulate_playout(self, node: MCTSNode, context: str, trace_id: str) -> float:
        current_state = node.state
        sim_path = [node.action] if node.action else []
        
        while not current_state.is_terminal:
            action = random.choice(current_state.get_possible_actions())
            sim_path.append(action)
            current_state = WargameState(current_state.market_share, current_state.turn + 1)
            
        prompt = f"Given industry context: {context[:500]}... Evaluate path: {' -> '.join(str(x) for x in sim_path)}"
        res = await async_llm_gateway(prompt, ModelTier.TIER_1_REASONING, complexity=3.0, trace_id=trace_id)
        
        return res["confidence_score"] if res["status"] == "success" else 0.5

    async def run_search(self, initial_state: WargameState, context: str, iterations: int, trace_id: str) -> str:
        logger.info(f"[{trace_id}] [MCTS 推演] 开始执行蒙特卡洛树搜索计算...")
        root = MCTSNode(initial_state)

        for _ in range(iterations):
            node = root
            while not node.state.is_terminal and len(node.children) == len(node.state.get_possible_actions()):
                node = node.best_child()

            if not node.state.is_terminal:
                tried_actions = [c.action for c in node.children]
                for act in node.state.get_possible_actions():
                    if act not in tried_actions:
                        new_state = WargameState(node.state.market_share, node.state.turn + 1)
                        new_node = MCTSNode(new_state, parent=node, action=act)
                        node.children.append(new_node)
                        node = new_node
                        break
            
            reward = await self.simulate_playout(node, context, trace_id)

            while node is not None:
                node.visits += 1
                node.value += reward
                node = node.parent
                
        best_action = root.best_child(exploration_weight=0).action
        logger.info(f"[{trace_id}] [MCTS 推演] 计算完成。推荐策略项: {best_action}")
        return best_action

