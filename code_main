def safe_json_loads(text: str, default: dict = None) -> dict:
    """JSON 解析器，处理模型输出中可能包含的格式化标记"""
    try:
        text = text.strip()
        # 使用字符拼接避免触发 Markdown 解析器截断
        markdown_json_prefix = '`' * 3 + 'json'
        markdown_prefix = '`' * 3
        
        if text.startswith(markdown_json_prefix): 
            text = text[7:]
        if text.startswith(markdown_prefix): 
            text = text[3:]
        if text.endswith(markdown_prefix): 
            text = text[:-3]
            
        return json.loads(text.strip())
    except Exception as e:
        logger.warning(f"JSON 解析失败，触发降级返回。错误信息: {e}")
        return default or {"status": "fallback_error", "extracted_points": 3, "confidence_score": 0.5}

