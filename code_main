# 并发限流器配置
CONCURRENCY_LIMIT = 20
global_semaphore = asyncio.Semaphore(CONCURRENCY_LIMIT)

USE_REAL_API = False  # 真实部署时设为 True
OPENAI_API_KEY = os.getenv("OPENAI_API_KEY", "your_openai_api_key_here")

try:
    from openai import AsyncOpenAI
    openai_client = AsyncOpenAI(api_key=OPENAI_API_KEY) if OPENAI_API_KEY else None
except ImportError:
    openai_client = None
    if USE_REAL_API:
        logger.warning("未检测到 openai 库，系统将切换为模拟运行模式。")
        USE_REAL_API = False

async def async_llm_gateway(
    prompt: str, 
    tier: ModelTier, 
    complexity: float = 1.0, 
    max_retries: int = 3,
    trace_id: str = "N/A"
) -> Dict[str, Any]:
    """包含并发限制与退避重试的 LLM 请求网关"""
    payload_size = len(prompt)
    attempt = 0
    
    async with global_semaphore:
        while attempt < max_retries:
            try:
                if USE_REAL_API and openai_client:
                    # 调用真实模型 API
                    model_name = "gpt-4o" if tier == ModelTier.TIER_1_REASONING else "gpt-4o-mini"
                    system_prompt = (
                        "You are a core agent in Nexus-Omni. "
                        "Output strictly JSON: {'status': 'str', 'extracted_points': int(1-10), 'confidence_score': float(0-1)}."
                    )
                    response = await openai_client.chat.completions.create(
                        model=model_name,
                        messages=[
                            {"role": "system", "content": system_prompt},
                            {"role": "user", "content": prompt}
                        ],
                        response_format={ "type": "json_object" },
                        timeout=45.0
                    )
                    
                    p_tokens = response.usage.prompt_tokens
                    c_tokens = response.usage.completion_tokens
                    content = safe_json_loads(response.choices[0].message.content)
                    
                    extracted_value = content.get("extracted_points", int(complexity * random.randint(3, 8)))
                    confidence = content.get("confidence_score", random.uniform(0.7, 0.99))
                    
                else:
                    # 模拟请求延迟与结果返回
                    await asyncio.sleep(random.uniform(0.1, 0.4) * complexity)
                    if random.random() < 0.01:
                        raise ConnectionError("Simulated API Rate Limit")
                    
                    p_tokens = int(payload_size * 1.5)
                    c_tokens = int(500 * complexity * random.uniform(0.8, 1.2))
                    extracted_value = int(complexity * random.randint(3, 8))
                    confidence = random.uniform(0.7, 0.99)
                
                # 记录资源消耗
                await global_token_mgr.record_usage(tier, p_tokens, c_tokens)
                
                return {
                    "status": "success",
                    "extracted_points": extracted_value,
                    "confidence_score": confidence,
                    "trace_id": trace_id
                }
                
            except BudgetExceededException:
                raise
            except Exception as e:
                attempt += 1
                backoff_time = (2 ** attempt) + random.uniform(0, 1)
                logger.warning(f"[Trace: {trace_id}] API调用异常 ({e})。第 {attempt}/{max_retries} 次重试，等待 {backoff_time:.1f} 秒...")
                await asyncio.sleep(backoff_time)
                
        logger.error(f"[Trace: {trace_id}] API 调用失败，达到最大重试次数。")
        return {"status": "failed", "extracted_points": 0, "confidence_score": 0.0}

