@dataclass
class PricingConfig:
    prompt_price_per_m: float  # 每百万 Token 的输入价格 (USD)
    comp_price_per_m: float    # 每百万 Token 的输出价格 (USD)

PRICING_TABLE = {
    ModelTier.TIER_1_REASONING: PricingConfig(5.0, 15.0),
    ModelTier.TIER_2_EXTRACTION: PricingConfig(0.25, 1.25)
}

class BudgetExceededException(Exception):
    """API 预算限制异常"""
    pass

class EnterpriseTokenManager:
    """Token 计费与预算管理模块"""
    def __init__(self, budget_usd: float = 1000.0):
        self.usage: Dict[ModelTier, Dict[str, int]] = {
            tier: {"prompt": 0, "completion": 0} for tier in ModelTier
        }
        self.budget_usd = budget_usd
        self.current_cost_usd = 0.0
        self._lock = asyncio.Lock()

    async def record_usage(self, tier: ModelTier, p_tokens: int, c_tokens: int):
        async with self._lock:
            self.usage[tier]["prompt"] += p_tokens
            self.usage[tier]["completion"] += c_tokens
            
            pricing = PRICING_TABLE[tier]
            cost_increase = (p_tokens / 1_000_000) * pricing.prompt_price_per_m + \
                            (c_tokens / 1_000_000) * pricing.comp_price_per_m
            self.current_cost_usd += cost_increase

            if self.current_cost_usd > self.budget_usd:
                logger.error(f"达到预算限制。已消耗: ${self.current_cost_usd:.2f}, 预算上限: ${self.budget_usd:.2f}")
                raise BudgetExceededException("API Budget Exceeded. System Halted.")

    def get_audit_data(self) -> dict:
        return {
            "total_cost_usd": round(self.current_cost_usd, 4),
            "tier_1_calls": self.usage[ModelTier.TIER_1_REASONING],
            "tier_2_calls": self.usage[ModelTier.TIER_2_EXTRACTION]
        }

global_token_mgr = EnterpriseTokenManager(budget_usd=5000.0)

