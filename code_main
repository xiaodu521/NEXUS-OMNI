class MockVectorDB:
    """向量数据库模拟模块"""
    def __init__(self):
        self.store: List[Dict[str, Any]] = []

    def ingest(self, doc_id: str, text: str):
        chunks = [text[i:i+4000] for i in range(0, len(text), 3500)]
        for i, chunk in enumerate(chunks):
            self.store.append({"doc_id": doc_id, "chunk_id": i, "content": chunk})
        logger.info(f"向量数据库: 文档 {doc_id} 写入完成，共计 {len(chunks)} 个数据块。")

    def similarity_search(self, query: str, top_k: int = 3) -> List[str]:
        if not self.store:
            return ["[Warning: VectorDB is empty. Proceeding with zero context.]"]
        results = random.sample(self.store, min(top_k, len(self.store)))
        return [res["content"] for res in results]

